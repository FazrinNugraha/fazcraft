---
import Layout from "../../layouts/Layout.astro";
import AppWrapper from "../../components/AppWrapper.tsx";

export async function getStaticPaths() {
    const posts = await Astro.glob('../../content/case-studies/*.md');
    
    return posts.map(post => {
        const slug = post.file.split('/').pop()?.split('.').shift() || '';
        return {
            params: { slug },
            props: { post }
        };
    });
}

const { post } = Astro.props;
const { Content } = post;
---

<Layout>
    <AppWrapper client:load page="case_study_detail" caseStudyFrontmatter={post.frontmatter}>
        <Content />
    </AppWrapper>
</Layout>
